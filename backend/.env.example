# ─── Base de datos ────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente al conectar el plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Generá un valor aleatorio seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_UN_VALOR_SECRETO_ALEATORIO

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL pública del frontend en Railway (ej: https://volcan-frontend.up.railway.app)
# Se configura DESPUÉS de crear el servicio frontend en Railway
FRONTEND_URL=https://TU-FRONTEND.up.railway.app
